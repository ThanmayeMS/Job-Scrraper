# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=JobRadar
ENVIRONMENT=development
DEBUG=true
# Comma-separated browser origins allowed to call the API, or * for all.
CORS_ORIGINS=*

# ── Database ──────────────────────────────────────────────────────────────────
# Inside docker-compose the host is "db"; locally it is "localhost".
DATABASE_URL=postgresql+psycopg://jobradar:jobradar@localhost:5432/jobradar

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL and CELERY_RESULT_BACKEND default to REDIS_URL if unset.

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a real one:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-please-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── OpenAI / LLM gateway ──────────────────────────────────────────────────────
# Option A — direct OpenAI: set OPENAI_API_KEY only.
OPENAI_API_KEY=
# Option B — any OpenAI-compatible endpoint (leave blank for direct OpenAI):
OPENAI_BASE_URL=
# Option C — Portkey gateway (takes priority if set). Keys live here, never in code.
PORTKEY_API_KEY=
PORTKEY_VIRTUAL_KEY=
SCORING_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# ── Matching ──────────────────────────────────────────────────────────────────
COSINE_THRESHOLD=0.55
MAX_LLM_SCORES_PER_RUN=150

# ── Scraper ───────────────────────────────────────────────────────────────────
SELENIUM_HEADLESS=true

# ── Background tasks ──────────────────────────────────────────────────────────
# Unset = auto (inline in dev, Celery/Redis in production). Set true to force inline
# execution so scraping/matching run in the web process with NO Redis/worker — ideal
# for a single free web service (e.g. Render free + Neon).
# RUN_TASKS_INLINE=true
